---
layout: null
---
[
{% for lecture in site.lectures %}
  {
    "title": {{ lecture.title | jsonify }},
    "url": {{ lecture.url | relative_url | jsonify }},
    "date": {{ lecture.date | date: "%Y-%m-%d" | jsonify }},
    "course": {{ lecture.course | jsonify }},
    "tags": {{ lecture.tags | jsonify }},
    "summary": {{ lecture.summary | jsonify }},
    "content": {{ lecture.content | strip_html | strip_newlines | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
